{
  "manifest_version": 3,
  "name": "FB AI Automation",
  "version": "1.0.0",
  "description": "Hệ thống tự động hóa Facebook với AI Gemini",
  "permissions": [
    "storage",
    "cookies",
    "tabs",
    "scripting",
    "notifications",
    "alarms"
  ],
  "host_permissions": [
    "https://*.facebook.com/*"
  ],
  "action": {
    "default_popup": "index.html",
    "default_width": 380,
    "default_height": 600
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["https://*.facebook.com/*"],
      "js": ["content.js"]
    }
  ]
}
